rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: queries
    // Document ID: query_{ra}_{dec} (hashed)
    // Fields:
    //   - ra: number (required) - Right Ascension
    //   - dec: number (required) - Declination
    //   - catalog_data: map (required) - Raw astronomical data
    //   - ai_summary: string (optional) - AI generated description
    //   - queried_at: timestamp (required) - Creation/Update time
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - role: string (required) - User role ('admin', 'user')
    //   - email: string (optional) - User email
    //   - displayName: string (optional) - User display name
    //   - createdAt: timestamp (optional) - Profile creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return true; // Bypassing auth check as requested
    }

    function isAdmin() {
      return true; // Simplified for this version without login
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidQuery(data) {
      return hasRequiredFields(['ra', 'dec', 'catalog_data', 'queried_at']) &&
             hasOnlyAllowedFields(['ra', 'dec', 'catalog_data', 'queried_at', 'ai_summary']) &&
             data.ra is number && 
             data.dec is number && 
             data.catalog_data is map &&
             data.queried_at is timestamp &&
             (!('ai_summary' in data) || (data.ai_summary is string && data.ai_summary.size() < 10000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /queries/{queryId} {
      // Public access allowed since login was removed
      allow read: if true;
      
      // Public create/update allowed if data is valid
      allow create, update: if isValidQuery(request.resource.data);
      
      // Allow delete for now (simplified)
      allow delete: if true;
    }
    
    match /users/{userId} {
      // Users collection is no longer used but we'll allow read for safety if any legacy data exists
      allow read: if true;
      allow write: if false;
    }
  }
}
