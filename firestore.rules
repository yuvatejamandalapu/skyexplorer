rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: queries
    // Fields:
    //   - ra: number (required)
    //   - dec: number (required)
    //   - catalog_data: map (required)
    //   - ai_summary: string (optional)
    //   - queried_at: timestamp (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidQuery(data) {
      return data.ra is number && 
             data.dec is number && 
             data.catalog_data is map &&
             data.queried_at is timestamp;
    }

    match /queries/{queryId} {
      // Anyone authenticated can read the cache
      allow read: if isAuthenticated();
      // Anyone authenticated can create a new cache entry if it's valid
      allow create: if isAuthenticated() && isValidQuery(request.resource.data);
      // No updates or deletes for now to keep the cache immutable
      allow update, delete: if false;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
